# Python caches and local environments
__pycache__/
*.py[cod]
backend/venv/

# Runtime databases (workflow definitions are exported to seed_projects.json)
backend/workflow_builder.db
backend/workflow_builder.db-shm
backend/workflow_builder.db-wal

# Project-local private inputs and generated execution output
backend/workspaces/*/.workflow_runs/
backend/workspaces/*/secrets/*
!backend/workspaces/*/secrets/.gitkeep
**/gcs-service-account*.json
*.log

# Frontend dependencies and build output
frontend/node_modules/
frontend/dist/
